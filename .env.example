# Copy to `.env` and fill in real values. Never commit .env.

# --- Database ---
DB_USER=stock_user
DB_PASSWORD=change_me
DB_HOST=localhost
DB_NAME=stock
DB_SCHEMA=stock
BACKTEST_SCHEMA=stock

# --- Local LLM (OpenAI-compatible endpoint: llama.cpp, vLLM, LM Studio) ---
LOCAL_LLM_URL=http://localhost:8080/v1
LOCAL_MODEL=qwen3.6-35b-a3b

# --- Remote LLM (used with `--remote`) ---
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o

# --- Context-window fallbacks (probed from /v1/models first) ---
LOCAL_CONTEXT_WINDOW=32768
REMOTE_CONTEXT_WINDOW=128000

# --- Auto-compaction thresholds ---
COMPACT_AT=0.75
COMPACT_KEEP_RECENT=4
MAX_RESPONSE_TOKENS=4096

# --- Agent loop ---
# How many ReAct iterations (= tool-call rounds) per invocation before giving up.
# Overridable per-call via --max-iterations.
MAX_ITERATIONS=12

# --- SEC EDGAR ---
# Required per SEC's fair-use policy. Any string identifying you + contact info.
# See https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=Stock Agent (your-email@example.com)

# --- Logging ---
LOG_LEVEL=INFO
